# Ignore all configuration files in the config directory except config.toml and profiles directory.
config/*
!config/profiles/
!config/config.toml

# Ignore all configuration profiles except development and unit test profiles.
config/profiles/*.toml
!config/profiles/dev*.toml
!config/profiles/unit-tests.toml